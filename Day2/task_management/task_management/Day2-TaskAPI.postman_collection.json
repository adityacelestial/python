              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "http://localhost:8000/users/login", "host": ["localhost"], "port": "8000", "path": ["users", "login"]}
