        },
        {
          "name": "Delete Non-Existent User (404)",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8000/users/9999", "host": ["localhost"], "port": "8000", "path": ["users", "9999"]}
          },
          "response": [],
          "description": "Expected status: 404 Not Found"
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fix login bug\",\n  \"description\": \"Users cannot log in on mobile\",\n  \"priority\": \"high\",\n  \"status\": \"pending\",\n  \"owner\": \"alice\"\n}"
            },
            "url": {"raw": "http://localhost:8000/tasks", "host": ["localhost"], "port": "8000", "path": ["tasks"]}
          },
          "response": [],
          "description": "Expected status: 201 Created"
        },
        {
          "name": "List All Tasks",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/tasks", "host": ["localhost"], "port": "8000", "path": ["tasks"]}
          },
          "response": [],
          "description": "Expected status: 200 OK"
        },
        {
          "name": "List Tasks - Filter by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/tasks?status=pending",
              "host": ["localhost"], "port": "8000", "path": ["tasks"],
              "query": [{"key": "status", "value": "pending"}]
            }
          },
          "response": [],
          "description": "Expected status: 200 OK — returns only pending tasks"
        },
        {
          "name": "List Tasks - Filter by Priority",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/tasks?priority=high",
              "host": ["localhost"], "port": "8000", "path": ["tasks"],
              "query": [{"key": "priority", "value": "high"}]
            }
          },
          "response": [],
          "description": "Expected status: 200 OK — returns only high priority tasks"
        },
        {
          "name": "List Tasks - Filter by Owner",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/tasks?owner=alice",
              "host": ["localhost"], "port": "8000", "path": ["tasks"],
              "query": [{"key": "owner", "value": "alice"}]
            }
          },
          "response": [],
          "description": "Expected status: 200 OK — returns only alice's tasks"
        },
        {
          "name": "List Tasks - Pagination",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/tasks?page=1&limit=5",
              "host": ["localhost"], "port": "8000", "path": ["tasks"],
              "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "5"}]
            }
          },
          "response": [],
          "description": "Expected status: 200 OK — paginated results"
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/tasks/1", "host": ["localhost"], "port": "8000", "path": ["tasks", "1"]}
          },
          "response": [],
          "description": "Expected status: 200 OK"
        },
        {
          "name": "Get Task Not Found (404)",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/tasks/9999", "host": ["localhost"], "port": "8000", "path": ["tasks", "9999"]}
          },
          "response": [],
          "description": "Expected status: 404 Not Found"
        },
        {
          "name": "Full Update Task (PUT)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fix login bug - UPDATED\",\n  \"description\": \"Resolved on iOS and Android\",\n  \"priority\": \"medium\",\n  \"status\": \"in_progress\",\n  \"owner\": \"alice\"\n}"
            },
            "url": {"raw": "http://localhost:8000/tasks/1", "host": ["localhost"], "port": "8000", "path": ["tasks", "1"]}
          },
          "response": [],
          "description": "Expected status: 200 OK — full replacement"
        },
        {
          "name": "Partial Update Task (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": {"raw": "http://localhost:8000/tasks/1", "host": ["localhost"], "port": "8000", "path": ["tasks", "1"]}
          },
          "response": [],
          "description": "Expected status: 200 OK — only status changed"
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8000/tasks/1", "host": ["localhost"], "port": "8000", "path": ["tasks", "1"]}
          },
          "response": [],
          "description": "Expected status: 200 OK"
        },
        {
          "name": "Delete Non-Existent Task (404)",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8000/tasks/9999", "host": ["localhost"], "port": "8000", "path": ["tasks", "9999"]}
          },
          "response": [],
          "description": "Expected status: 404 Not Found"
        }
      ]
    },
