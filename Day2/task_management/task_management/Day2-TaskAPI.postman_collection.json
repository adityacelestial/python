          "response": [],
          "description": "Expected status: 200 OK"
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8000/users/1", "host": ["localhost"], "port": "8000", "path": ["users", "1"]}
