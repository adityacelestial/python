  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@mail.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "http://localhost:8000/users/register", "host": ["localhost"], "port": "8000", "path": ["users", "register"]}
          },
          "response": [],
          "_postman_previewlanguage": "json",
          "description": "Expected status: 201 Created"
        },
        {
          "name": "Register Duplicate User (409)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@mail.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "http://localhost:8000/users/register", "host": ["localhost"], "port": "8000", "path": ["users", "register"]}
          },
          "response": [],
